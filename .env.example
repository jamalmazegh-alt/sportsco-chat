# Public, build-time env (safe to ship to the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-side mirror used by the TanStack server runtime
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# === Server-only secrets — NEVER commit real values. Configure them in the
# hosting environment / Supabase Edge Function Secrets, not in this repo. ===
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (platform account + Connect)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Cron / public hook shared secret
DATA_RETENTION_SECRET=

# Lovable AI Gateway
LOVABLE_API_KEY=

# Optional app config
APP_URL=
